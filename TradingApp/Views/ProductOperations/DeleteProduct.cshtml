@using TradingApp.ViewModels.InputProduct;
@model DeletedProductModel

@{
    ConfirmationHelper confirmationHelper = new ConfirmationHelper()
    {
        Message = $"Are you sure you want to delete product {Model.ProductName}?",
        Controller = "ProductOperations",
        Action = "DeleteProduct_execute",
        ProductId = Model.ProductId
    };
}

<partial name="_ProductConfirmation" model="confirmationHelper"></partial>
