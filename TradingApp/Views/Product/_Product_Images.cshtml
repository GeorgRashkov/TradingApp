@using TradingApp.ViewModels.Product;
@model ProductViewModel

@{
    List<string> imageNames = new List<string>() { "front", "back", "top", "bottom", "left", "right" };
}

<div class="container py-4">

    <div class="row row-cols-1 row-cols-sm-2 g-2">

        @for (int i = 0; i < 6; i++)
        {
            <div class="col">

                <div class="card h-100 shadow-sm">

                    <img class="card-img-top img-fluid product-img"
                         src="~/Creators/@(Model.CreatorName)/@(Model.ProductName)/@(imageNames[i]).jpg"
                         alt="@(Model.ProductName)" />

                    <div class="card-body text-center">

                        <h6 class="card-title fw-semibold">
                            @(imageNames[i])
                        </h6>

                    </div>

                </div>

            </div>
        }

    </div>

</div>
