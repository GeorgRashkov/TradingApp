
@using TradingApp.ViewModels.Product;
@using TradingApp.Data.Enums;

@model MyProductViewModel
@{
    ViewData["Title"] = Model.ProductName;
    List<string> imageNames = new List<string>() { "front", "back", "top", "bottom", "left", "right" };
    bool maxSellOrdersCountReached = (bool)(ViewData["maxSellOrdersCountReached"] as bool?);
}




<h1>@Model.ProductName</h1>


<div class="container py-4">

    <div class="row row-cols-1 row-cols-sm-2 g-2">

        @for (int i = 0; i < 6; i++)
        {
            <div class="col">

                <div class="card h-100 shadow-sm">

                    <img class="card-img-top img-fluid product-img"
                         src="~/Creators/@(Model.CreatorName)/@(Model.ProductName)/@(imageNames[i]).jpg"
                         alt="@Model.ProductName" />

                    <div class="card-body text-center">

                        <h6 class="card-title fw-semibold">
                            @imageNames[i]
                        </h6>

                    </div>

                </div>

            </div>
        }

    </div>

</div>

<br />

<div>
    <p>@Model.Description</p>
</div>

<br />


<p>Price: @(Model.Price)$</p>


<a class="btn btn-sm btn-primary" asp-controller="ProductOperations" asp-action="UpdateProduct" asp-route-productId="@(Model.Id)">Edit</a>
<a class="btn btn-sm btn-primary" asp-controller="ProductOperations" asp-action="DeleteProduct">Delete</a>
<br />
<br />

@if (Model.ProductStatus != ProductStatus.approved.ToString())
{
    <p><b>This product cannot be sold currently because it's status is @(Model.ProductStatus)!</b></p>
}
else if (Model.HasActiveSellOrder == true)
{
    <a class="btn btn-sm btn-primary" asp-controller="ProductOperations" asp-action="CancelSellOrder">Cancel sell order</a>
}
else if (maxSellOrdersCountReached == true)
{
    <p><b>Active sales maximum amount reached!</b></p>
}
else
{
    <a class="btn btn-sm btn-primary" asp-controller="ProductOperations" asp-action="CreateSellOrder">Create sell order</a>
}



<style>
    .product-img {
        height: 500px;
        object-fit: contain;
        padding: 15px;
    }
</style>