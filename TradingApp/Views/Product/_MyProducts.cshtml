@using TradingApp.ViewModels.Product;
@model List<MyProductsViewModel>

<div class="container py-4">

    <div class="row row-cols-1 row-cols-sm-2 g-2">

        @foreach (var product in Model)
        {
            <div class="col">

                <div class="card h-100 shadow-sm">

                    <img class="card-img-top img-fluid product-img"
                         src="~/Creators/@(product.CreatorName)/@(product.ProductName)/front.jpg"
                         alt="@product.ProductName" />

                    <div class="card-body text-center">

                        <h6 class="card-title fw-semibold">
                            @product.ProductName
                        </h6>

                        <h6>
                            Status: @product.ProductStatus
                        </h6>

                        <p class="card-text text-muted mb-2">
                            $@product.Price
                        </p>

                        <a class="btn btn-sm btn-primary" asp-controller="Product" asp-action="MyProduct" asp-route-productId="@(product.Id)">
                            View
                        </a>
                        <a class="btn btn-sm btn-primary" asp-controller="ProductOperations" asp-action="UpdateProduct" asp-route-productId="@(product.Id)">
                            Edit
                        </a>
                        <a class="btn btn-sm btn-primary" asp-controller="ProductOperations" asp-action="DeleteProduct" asp-route-productId="@(product.Id)">
                            Delete
                        </a>


                    </div>

                </div>

            </div>
        }

    </div>

</div>