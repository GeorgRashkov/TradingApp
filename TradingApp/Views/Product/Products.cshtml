@using TradingApp.ViewModels.Product;
@model List<ProductsViewModel>
@{
    ViewData["Title"] = "Products";
   
    PaginationHelper paginationHelper = new PaginationHelper()
    {
        Controller = "Product",
        Action = (string)(ViewData["action"] ?? "Products"),
        PageIndex = (int)(ViewData["page"] ?? 0)
    };    
}

<div class="row row-cols-1 row-cols-sm-2 g-2">
    <div style="text-align:left">
        <h1>@(ViewData["Title"])</h1>
    </div>

</div>
<br />

@if (Model is null)
{
    <h2>No products found!</h2>
}
else
{
    <partial name="_Products" model="@(Model)"></partial>

    <partial name="_Pagination" model="@(paginationHelper)"></partial>

    @section Styles {
        <partial name="_ProductStyle"></partial>
    }
}
