@using TradingApp.ViewModels.Product;
@model List<ProductsViewModel>
@{
    ViewData["Title"] = "Products";
   
    PaginationHelper paginationHelper = new PaginationHelper()
    {
        Controller = "Product",
        Action = "Products",
        PageIndex = (int)(ViewData["page"] ?? 0)
    };    
}

<div class="row row-cols-1 row-cols-sm-2 g-2">
    <div style="text-align:left">
        <h1>@(ViewData["Title"])</h1>
    </div>

</div>
<br />

@if (Model is null)
{
    <h2>No products found!</h2>
}
else
{
    <div class="container py-4">

        <div class="row row-cols-1 row-cols-sm-2 g-2">

            @foreach (var product in Model)
            {
                <div class="col">

                    <div class="card h-100 shadow-sm">

                        <img class="card-img-top img-fluid product-img"
                             src="~/Creators/@(product.CreatorName)/@(product.ProductName)/front.jpg"
                             alt="@product.ProductName" />

                        <div class="card-body text-center">

                            <h6 class="card-title fw-semibold">
                                @product.ProductName
                            </h6>

                            <h6>
                                Created by @product.CreatorName
                            </h6>

                            <p class="card-text text-muted mb-2">
                                $@product.Price
                            </p>

                            <a class="btn btn-sm btn-primary" asp-controller="Product" asp-action="Product" asp-route-productId="@(product.Id)">
                                View
                            </a>


                            <a class="btn btn-sm btn-primary" asp-controller="Order" asp-action="BuySellOrder" asp-route-productId="@(product.Id)">
                                Buy
                            </a>


                        </div>

                    </div>

                </div>
            }

        </div>

    </div>

    <partial name="_Pagination" model="@(paginationHelper)"></partial>
   

    <style>
        .product-img {
            height: 300px;
            object-fit: contain;
            padding: 15px;
        }
    </style>
}
