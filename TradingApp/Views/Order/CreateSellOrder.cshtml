@using TradingApp.ViewModels.Order;
@model OrderViewModel

@{
    ConfirmationHelper confirmationHelper = new ConfirmationHelper()
    {
        Message = Model.Message,
        Controller = "Order",
        Action = "CreateSellOrder_execute",
        ProductId = Model.ProductId,
        OrdersCount = Model.OrdersCount
    };
}

<partial name="_ProductConfirmation" model="confirmationHelper"></partial>
