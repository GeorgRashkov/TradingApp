@{
    string title = TempData["title"] as string ?? "message";
    ViewData["Title"] = title;

    string defaultMessage = title.ToLower() == "error" ? "An error occurred." : "Operation completed successfully.";

    string message = (TempData["message"] as string ?? "").Trim();
    message = message == "" ? defaultMessage : message;
}

<h1>@(message)</h1>